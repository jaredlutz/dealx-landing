# Canonical site URL for SEO (metadataBase, sitemap, robots, JSON-LD). No trailing slash.
NEXT_PUBLIC_APP_URL=https://www.diversyfund.com

# Portal URL for sign-up, sign-in, and eligibility redirects
NEXT_PUBLIC_PORTAL_URL=https://portal.diversyfund.com

# --- Public marketing forms (set on Vercel for staging/prod) ---
#
# Investment interest (modal + sticky “Start Eligibility Review” / Invest CTAs) → POST /api/investment-interest
# Required if you want leads in CRM. If unset, the site still shows success but data only goes to server logs.
# Must be the full API URL (not just https://crm.diversyfund.com). Confirm the path with df-crm (same family as marketing-site contact).
# Example prod shape (path is illustrative until CRM exposes it):
# INVESTMENT_INTEREST_WEBHOOK_URL=https://crm.diversyfund.com/api/public/marketing-site/investment-interest
# INVESTMENT_INTEREST_WEBHOOK_SECRET=

# /contact page → df-crm ingest (server-side POST)
# Prod: https://<crm-host>/api/public/marketing-site/contact
# Local df-crm dev is port 3002
# CRM_CONTACT_FORM_URL=http://localhost:3002/api/public/marketing-site/contact
# CRM_CONTACT_FORM_SECRET=

# /support page → diversyfund-portal ingest (server-side POST; browser never sees this URL)
# Prod: https://<portal-host>/api/public/marketing-site/support
# Local portal dev is port 3005 (see ../PORTS.md in your Github folder)
# PORTAL_SUPPORT_FORM_URL=http://localhost:3005/api/public/marketing-site/support
# PORTAL_SUPPORT_FORM_SECRET=

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# WorkOS AuthKit – required for /admin. Get from https://dashboard.workos.com/
WORKOS_API_KEY=sk_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=<min 32 chars, e.g. openssl rand -base64 32>
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Optional: restrict admin sign-in to your org only
# WORKOS_ORGANIZATION_ID=org_...