# Canonical site URL for SEO (metadataBase, sitemap, robots, JSON-LD). No trailing slash.
NEXT_PUBLIC_APP_URL=https://www.diversyfund.com

# Portal URL for sign-up, sign-in, and eligibility redirects
NEXT_PUBLIC_PORTAL_URL=https://portal.diversyfund.com

# --- Public marketing forms (set on Vercel for staging/prod) ---
#
# Investment interest (modal + sticky “Book Appointment” / Invest CTAs) → POST /api/investment-interest
# Required if you want leads in CRM. If unset, the site still shows success but data only goes to server logs.
# Must be the full API URL (not just https://crm.diversyfund.com). Confirm the path with df-crm (same family as marketing-site contact).
# Example prod shape (path is illustrative until CRM exposes it):
# INVESTMENT_INTEREST_WEBHOOK_URL=https://crm.diversyfund.com/api/public/marketing-site/investment-interest
# INVESTMENT_INTEREST_WEBHOOK_SECRET=

# `/premier-program` seat request → POST /api/premier-seat-request → df-crm `/api/public/marketing-site/premier-program`
# Same secret must be set on df-crm as `PREMIER_PROGRAM_WEBHOOK_SECRET`.
# PREMIER_PROGRAM_WEBHOOK_URL=http://localhost:3002/api/public/marketing-site/premier-program
# PREMIER_PROGRAM_WEBHOOK_SECRET=
#
# Legacy names (optional): if `PREMIER_PROGRAM_*` unset, LP still reads `PREMIER_SEAT_REQUEST_WEBHOOK_URL` / `PREMIER_SEAT_REQUEST_WEBHOOK_SECRET`.
#
# df-crm (optional): `PREMIER_PROGRAM_BOOKING_WORKFLOW_ID` — `GET .../premier-booking-url?variant=in_person`
# df-crm (optional): `PREMIER_PROGRAM_BOOKING_CALL_WORKFLOW_ID` — `?variant=call`; if unset, CRM uses `{NEXT_PUBLIC_APP_URL}/book/investor-call`
# df-crm (optional): `DF_WEBSITE_PREMIER_PROGRAM_WORKFLOW_CAMPAIGN_ID` — fallback when tag→campaign map has no Premier entries
# Legacy alias on df-crm: `FIXED_NOTE_LP_PREMIER_PROGRAM_WORKFLOW_CAMPAIGN_ID`

# /contact page → df-crm ingest (server-side POST)
# Prod: https://<crm-host>/api/public/marketing-site/contact
# Local df-crm dev is port 3002
# CRM_CONTACT_FORM_URL=http://localhost:3002/api/public/marketing-site/contact
# CRM_CONTACT_FORM_SECRET=

# /support page → diversyfund-portal ingest (server-side POST; browser never sees this URL)
# Prod: https://<portal-host>/api/public/marketing-site/support
# Local portal dev is port 3005 (see ../PORTS.md in your Github folder)
# PORTAL_SUPPORT_FORM_URL=http://localhost:3005/api/public/marketing-site/support
# PORTAL_SUPPORT_FORM_SECRET=

# `/webinar-registration` scorecard → df-crm `/api/lp/vsl-investor-questionnaire`
# Mirrors the existing VSL investor quiz funnel (flow=vsl_investor_quiz_v1).
# If unset, the LP scores submissions locally using the mirrored rubric and the user still gets a result snapshot,
# but no contact is created in CRM. The optional secret is forwarded as Bearer auth (the df-crm route currently
# does not require it, but the secret stays compatible for a future bearer-secured public endpoint).
# WEBINAR_SCORECARD_WEBHOOK_URL=http://localhost:3002/api/lp/vsl-investor-questionnaire
# WEBINAR_SCORECARD_WEBHOOK_SECRET=

# Database (Neon Postgres) — LP marketing CMS (`content_blocks`, `testimonials`)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Portal database (Neon Postgres) — same connection string as diversyfund-portal for live offering copy on
# marketing opportunity pages. Optional: if unset, pages use baked-in snapshots (CI / local without portal DB).
# PORTAL_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# `/opportunities/df-income` — optional portal UUID for live copy (requires PORTAL_DATABASE_URL)
# NEXT_PUBLIC_DF_INCOME_OFFERING_ID=
# Legacy alias (still read as fallback by `lib/df-income.js`):
# NEXT_PUBLIC_DISTRESSED_MF_NOTES_OFFERING_ID=

# WorkOS AuthKit – required for /admin AND for the public Insights & Education sign-up gate.
# AuthKit middleware runs on /admin + /callback + /insights-education/* + /api/insights-signup/* +
# /api/insights-unlock. The Insights gate is **fully self-hosted on the LP** (no redirect to the
# WorkOS hosted chooser UI):
#   - Email/password — the inline form posts to `/api/insights-unlock` which calls
#     `userManagement.createUser` + `authenticateWithPassword` + `saveSession` server-side to mint
#     a real WorkOS user and a live AuthKit session. Keep the dashboard password minimum at 8+
#     chars to match the client-side validator.
#   - LinkedIn — `/api/insights-signup/linkedin/start` deep-links via WorkOS's built-in
#     `provider: "LinkedInOAuth"` (Authentication → Social → LinkedIn OAuth in the dashboard;
#     toggle Enable and paste your LinkedIn Client ID/Secret). The visitor sees LinkedIn's OAuth
#     page directly — no per-app `WORKOS_LINKEDIN_CONNECTION_ID` env var needed. The `/callback`
#     redirect URI is already registered for admin auth.
# Get from https://dashboard.workos.com/
WORKOS_API_KEY=sk_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=<min 32 chars, e.g. openssl rand -base64 32>
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Optional: restrict admin sign-in to your org only
# WORKOS_ORGANIZATION_ID=org_...

# --- Insights & Education (df-crm portal_article feed) ---
# Full URL to the list endpoint (no trailing slash). Must match INSIGHTS_EDUCATION_FEED_SECRET on df-crm.
# INSIGHTS_EDUCATION_FEED_URL=https://crm.diversyfund.com/api/public/insights-education
# INSIGHTS_EDUCATION_FEED_SECRET=

# --- Book LPs (/book/*) — PostHog + CRM proxy ---
# Same PostHog project as df-crm (306886)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_STRICT_EVENTS=1
# NEXT_PUBLIC_META_PIXEL_ID=
# CRM_API_BASE_URL=https://crm.diversyfund.com
# CRM_BOOK_PROXY_SECRET=  # must match df-crm CRM_BOOK_PROXY_SECRET (also used as DF_INCOME_DECK_SIGNUP_WEBHOOK_SECRET fallback)
# DF_INCOME_DECK_SIGNUP_WEBHOOK_URL=https://crm.diversyfund.com/api/public/marketing-site/df-income-deck-signup
# DF_INCOME_DECK_SIGNUP_WEBHOOK_SECRET=  # same as CRM_BOOK_PROXY_SECRET